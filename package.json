{
  "name": "licensed-ci",
  "version": "1.11.1",
  "description": "GitHub Actions CI workflow for licensee/licensed",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint lib test",
    "test": "npm run lint && NODE_OPTIONS=--experimental-vm-modules jest",
    "package": "ncc build lib/index.js -o dist",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/licensee/licensed-ci.git"
  },
  "keywords": [
    "GitHub",
    "Licensed"
  ],
  "author": "Jon Ruskin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/licensee/licensed-ci/issues"
  },
  "homepage": "https://github.com/licensee/licensed-ci#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/io": "^3.0.2",
    "@octokit/plugin-throttling": "^11.0.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.44",
    "babel-jest": "^30.4.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4",
    "sinon": "^22.0.0"
  }
}
